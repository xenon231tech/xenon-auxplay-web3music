# Environment Variables Example

# API Configuration
VITE_API_URL=http://localhost:3000/api
VITE_API_VERSION=v1
VITE_API_TIMEOUT=30000

# Web3 Configuration
VITE_CHAIN_ID=8453
VITE_CHAIN_NAME=Base
VITE_RPC_URL=https://mainnet.base.org
VITE_EXPLORER_URL=https://basescan.org

# Smart Contracts
VITE_AUX_TOKEN_ADDRESS=0x...
VITE_STREAMING_CONTRACT_ADDRESS=0x...
VITE_CREATOR_REGISTRY_ADDRESS=0x...

# Wallet Configuration
VITE_WALLET_CONNECT_ID=YOUR_PROJECT_ID
VITE_INFURA_ID=YOUR_INFURA_ID
VITE_ALCHEMY_KEY=YOUR_ALCHEMY_KEY

# Analytics
VITE_GOOGLE_ANALYTICS_ID=G-...
VITE_SENTRY_DSN=https://...

# App Configuration
VITE_APP_NAME=Auxplay
VITE_APP_DESCRIPTION=The Decentralized Audio Hub on Base
VITE_APP_URL=https://auxplay.io
VITE_APP_LOGO=https://auxplay.io/logo.png

# Feature Flags
VITE_ENABLE_WEB3=true
VITE_ENABLE_STREAMING=false
VITE_ENABLE_CREATOR_DASHBOARD=false
VITE_MAINTENANCE_MODE=false

# Email Configuration
VITE_EMAIL_SERVICE=gmail
VITE_EMAIL_FROM=noreply@auxplay.io

# Security
VITE_JWT_SECRET=your_jwt_secret_key
VITE_ENCRYPTION_KEY=your_encryption_key

# Limits
VITE_MAX_UPLOAD_SIZE=100000000
VITE_MAX_REQUESTS_PER_MINUTE=100
VITE_MAX_REQUESTS_PER_HOUR=1000
